class Solution {
    public int myAtoi(String s) {
        // Skipping the Leading Spaces
        s = s.trim();
        if(s.length() <= 0) return 0;
        
        // Handling + and -
        int i = 0;
        int sign = 1;
        if(s.charAt(i) == '-'){
            sign = -1;
            i++;
        }else if(s.charAt(i) == '+') i++;

        // Removing Leading zeros
        while ((i<s.length()) && s.charAt(i) == '0') i++;

        long res = 0L;          // Variable to store the curr Value
        // Integer Characters
        while (i<s.length()) {
            Character currChar = s.charAt(i);
            if(Character.isDigit(currChar)){
                res = res * 10 + (currChar - '0');

                // Checking if current Res is more than the Limit
                // We check against the 32-bit integer limits
                if(sign * res >= Integer.MAX_VALUE) return Integer.MAX_VALUE;
                else if(sign * res <= Integer.MIN_VALUE) return Integer.MIN_VALUE;
            }else break;
            i++;
        }
        return (int) (res * sign);
    }
}
